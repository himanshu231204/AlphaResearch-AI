# AlphaResearch AI - Environment Variables
# Copy this file to .env and fill in your API keys

# Google Gemini (Primary reasoning model)
GEMINI_API_KEY=your_gemini_api_key_here

# xAI / Grok (Fast research model)
XAI_API_KEY=your_xai_api_key_here

# LiteLLM Master Key (for unified routing)
LITELLM_MASTER_KEY=your_litellm_master_key_here

# Financial Data APIs
FINNHUB_API_KEY=your_finnhub_api_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here

# Search APIs (Tavily recommended — free tier: 1000 credits/month at tavily.com)
TAVILY_API_KEY=your_tavily_api_key_here
GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
GOOGLE_SEARCH_CX=your_google_custom_search_engine_id_here
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# LangSmith Observability
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=alpha-research-ai
