# ╔══════════════════════════════════════════════════════════════╗
# ║  AlphaResearch AI — Environment Variables                   ║
# ║  Copy to .env and fill in your keys                        ║
# ╚══════════════════════════════════════════════════════════════╝

# ─── LLM Providers ───────────────────────────────────────────
# Gemini 2.5 Flash (planning, reflection, report writing, fallback)
# Get key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq Llama 3.3 70B (research, technical analysis, quick summary)
# Get key at: https://console.groq.com
GROQ_API_KEY=

# OpenRouter — Nex N2 Pro (financial analysis, free)
# Get key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── Financial Data APIs ─────────────────────────────────────
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ─── Web Search ──────────────────────────────────────────────
# Free (no key needed):
#   - web_search       → Your MCP server (mcp-web-search on Render)
#   - duckduckgo_search → Local DuckDuckGo (ddgs library)
#   - fetch_web_page    → Your MCP server page extraction
#
# Free with API key (recommended):
#   - tavily_search    → AI-optimized search (1000 credits/month free)
#   - tavily_extract   → Clean page extraction
#   Get key at: https://tavily.com

TAVILY_API_KEY=

# Optional paid fallbacks (auto-fallback to DuckDuckGo if not set):
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=
BRAVE_SEARCH_API_KEY=

# ─── Observability (LangSmith) ──────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=alpha-research-ai
